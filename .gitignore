# - Database credentials:

# 1. File con le credenziali del database
config/database.php

# - Environment variables:

# 1. File con le variabili d'ambiente
.env

# - Composer:

# 1. Cartella con le librerie installate (si ricrea con "composer install")
vendor/

# - System files:

# 1. File nascosto che Mac crea automaticamente 
.DS_Store 

# 2. File nascosto che Windows crea nelle cartelle con immagini
Thumbs.db

# - Editor files:

# 1. Le impostazioni personali di VS Code
.vscode/

# 2. Qualsiasi file che finisce in .log (file di errori)
*.log